		"postcss": "^8.5.1",
		"prisma": "^6.4.0",
		"supabase": "^2.9.6",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.0.0",
		"vite": "^6.0.0"
	},
	"dependencies": {
		"@prisma/client": "^6.4.0",
		"@supabase/ssr": "^0.5.2",
		"@supabase/supabase-js": "^2.48.1",
